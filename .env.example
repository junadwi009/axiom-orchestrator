# =============================================================================
# axiom-orchestrator — .env.example
# Template environment variables untuk stack axiom + crypto-bot.
# =============================================================================
# USAGE:
#   1. Copy ke .env:
#        Ubuntu : cp .env.example .env
#        Windows: Copy-Item .env.example .env
#   2. Jalankan setup_local.sh / setup_local.ps1.
#      Script akan replace REPLACE_<NAMA> placeholders dengan password random
#      dan tulis backup kredensial ke credentials.txt (jangan commit).
#   3. Isi manual field bertanda "# wajib isi manual" (API keys, Telegram tokens).
#   4. chmod 600 .env (Ubuntu) — file ini berisi rahasia.
#
# REFERENSI:
#   - docker-compose.yaml      (env vars yang di-consume tiap service)
#   - INTEGRATION_GUIDE.md §6  (full secret list)
#   - DEVELOPMENT_ROADMAP.md §1.4 (M1 minimum env)
#
# ATURAN OPERASIONAL (locked per Konflik 10):
#   - INITIAL_CAPITAL=213
#   - DAILY_TARGET_PCT=3.0   (turun dari 9.1%; AI may propose adjustment via Channel B)
#   - DRAWDOWN_LIMIT_PCT=15.0 (hard guillotine)
#   - PAPER_TRADE=true        (live hanya setelah validasi R10 — 90d backtest + 14d paper)
# =============================================================================


# -----------------------------------------------------------------------------
# 1. POSTGRES SUPERUSER (init.sql + admin tasks)
# -----------------------------------------------------------------------------
DB_ADMIN_USER=aru_admin
DB_ADMIN_PASSWORD=REPLACE_DB_ADMIN_PW


# -----------------------------------------------------------------------------
# 2. APPLICATION DATABASES (5 user roles per DATABASE_SCHEMA.md §5)
# -----------------------------------------------------------------------------
# Container service connect via pgbouncer (transaction pooling).
#
# Untuk akses dari host laptop (mis. python backtest.py local atau psql direct):
#   DB_HOST=localhost
#   DB_PORT=6432
# Container service WAJIB pakai hostname Docker network (axiom_pgbouncer).
DB_HOST=axiom_pgbouncer
DB_PORT=6432

DB_NAME_AXIOM=axiom_memories
DB_NAME_CRYPTOBOT=cryptobot_db

DB_USER_AXIOM=axiom_user
DB_PASSWORD_AXIOM=REPLACE_AXIOM_DB_PW

DB_USER_CRYPTOBOT=cryptobot_user
DB_PASSWORD_CRYPTOBOT=REPLACE_CRYPTOBOT_DB_PW

DB_USER_OBSERVER=readonly_observer
DB_PASSWORD_OBSERVER=REPLACE_OBSERVER_DB_PW

DB_USER_PARAMSYNC=parameter_sync_user
DB_PASSWORD_PARAMSYNC=REPLACE_PARAMSYNC_DB_PW

DB_USER_N8N=n8n_user
DB_PASSWORD_N8N=REPLACE_N8N_DB_PW


# -----------------------------------------------------------------------------
# 3. PGBOUNCER ADMIN CONSOLE
# -----------------------------------------------------------------------------
PGB_ADMIN_USER=pgbouncer_admin
PGB_ADMIN_PASSWORD=REPLACE_PGB_ADMIN_PW


# -----------------------------------------------------------------------------
# 4. REDIS
# -----------------------------------------------------------------------------
REDIS_PASSWORD=REPLACE_REDIS_PW
REDIS_URL=redis://:REPLACE_REDIS_PW@axiom_redis:6379


# -----------------------------------------------------------------------------
# 5. n8n WORKFLOW ENGINE
# -----------------------------------------------------------------------------
N8N_HOST=axiom_n8n
N8N_USER=admin
N8N_PASSWORD=REPLACE_N8N_BASIC_PW
WEBHOOK_URL=http://axiom_n8n:5678/webhook/


# -----------------------------------------------------------------------------
# 6. EXTERNAL LLM API KEYS — wajib isi manual
# -----------------------------------------------------------------------------
# OpenRouter (axiom council: Hermes-3 + Hermes-4)
# Source: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Anthropic (crypto-bot brain: Haiku / Sonnet / Opus)
# Source: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Soft cap internal — crypto-bot's settings.py membaca ini untuk warn/throttle
# sebelum hit Anthropic console hard limit. USD per bulan.
ANTHROPIC_SPENDING_LIMIT=30


# -----------------------------------------------------------------------------
# 7. TELEGRAM BOTS (DUA TOKEN — Konflik 3 resolution)
# -----------------------------------------------------------------------------
# Bot 1 (axiom council) — buat di @BotFather: /newbot
TELEGRAM_BOT_TOKEN_AXIOM=

# Bot 2 (crypto-bot dashboard) — token TERPISAH di @BotFather
TELEGRAM_BOT_TOKEN_CRYPTOBOT=

# Aru's numeric chat_id (sama untuk kedua bot) — get from @userinfobot
TELEGRAM_CHAT_ID=

# Comma-separated Telegram user IDs yang authorized (selain TELEGRAM_CHAT_ID).
# Format: 123456,789012,345678
# Default kosong = hanya TELEGRAM_CHAT_ID yang boleh akses.
TELEGRAM_AUTHORIZED_USERS=


# -----------------------------------------------------------------------------
# 8. BYBIT EXCHANGE — wajib isi manual
# -----------------------------------------------------------------------------
# Source: Bybit dashboard > API Management
# Permission MINIMUM: read + trade.  JANGAN aktifkan withdraw.
# Production: set IP whitelist ke VPS IP (MIGRATION_GUIDE §10).
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true


# -----------------------------------------------------------------------------
# 9. BOT OPERATIONAL PARAMETERS (locked per Konflik 10)
# -----------------------------------------------------------------------------
INITIAL_CAPITAL=213
DAILY_TARGET_PCT=3.0
DRAWDOWN_LIMIT_PCT=15.0
PAPER_TRADE=true
BOT_TIMEZONE=Asia/Jakarta


# -----------------------------------------------------------------------------
# 10. AUTH — wajib isi manual
# -----------------------------------------------------------------------------
# Bcrypt hash dari PIN dashboard crypto-bot.
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PIN', bcrypt.gensalt()).decode())"
# Cost factor default 12 (bcrypt.gensalt()) — aman untuk M1.
BOT_PIN_HASH=


# -----------------------------------------------------------------------------
# 11. AI FEATURE FLAGS
# -----------------------------------------------------------------------------
# All Phase 3-4 features default OFF. Enable only after R10 validation:
#   Layer 3 needs ≥30d Layer 1+2 stable.
#   Layer 4 needs ≥60d Layer 3 stable.
FEATURE_PATTERN_LAYER1_ENABLED=false
FEATURE_PATTERN_LAYER2_ENABLED=false
FEATURE_RL_LAYER3_ENABLED=false
FEATURE_SELF_MODIFY_LAYER4_ENABLED=false
FEATURE_AUTO_PARAM_REWRITE=false
FEATURE_AUTO_CODE_REWRITE=false


# -----------------------------------------------------------------------------
# 12. FRONTEND (Phase 2+ — production)
# -----------------------------------------------------------------------------
# Kosong untuk M1. Set ke domain VPS post-Phase 2.
FRONTEND_URL=


# -----------------------------------------------------------------------------
# 13. VPS METADATA (Phase 2+ — pasca-provisioning Contabo)
# -----------------------------------------------------------------------------
VPS_IP=


# -----------------------------------------------------------------------------
# 14. BACKUP — Backblaze B2 (Phase 2+ — weekly DB upload)
# -----------------------------------------------------------------------------
# Source: https://secure.backblaze.com/app_keys.htm
BACKBLAZE_B2_KEY_ID=
BACKBLAZE_B2_APP_KEY=
BACKBLAZE_B2_BUCKET=axiom-backups
