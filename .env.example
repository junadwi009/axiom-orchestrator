# =============================================================================
# axiom-orchestrator + crypto-bot — combined .env.example
# =============================================================================
# Copy ke .env dan isi semua field. Jangan pernah commit .env ke git.
# Permission saat production: chmod 600 .env
# =============================================================================

# === BYBIT EXCHANGE ===
# Get from: https://www.bybit.com → API Management
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true                  # set false di production

# === ANTHROPIC API (untuk crypto-bot brain: Haiku/Sonnet/Opus) ===
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
ANTHROPIC_SPENDING_LIMIT=30         # USD per month, default 30

# === OPENROUTER API (untuk axiom Hermes Council) ===
# Get from: https://openrouter.ai → Keys
OPENROUTER_API_KEY=

# === TELEGRAM — DUA BOT TERPISAH ===
# Bot 1: untuk axiom (council debate, observer alerts)
# Get token from BotFather: /newbot
TELEGRAM_BOT_TOKEN_AXIOM=

# Bot 2: untuk crypto-bot (trading commands, status)
# Token terpisah, BotFather → /newbot lagi
TELEGRAM_BOT_TOKEN_CRYPTOBOT=

# Aru's chat_id (dari @userinfobot di Telegram)
# Sama untuk kedua bot — satu user, dua percakapan terpisah
TELEGRAM_CHAT_ID=

# === DATABASE (PostgreSQL 16 + TimescaleDB) ===
# Untuk M1 (local Docker): DB_HOST=localhost
# Untuk M2+ (VPS Docker): DB_HOST=axiom_pgbouncer
DB_HOST=axiom_pgbouncer
DB_PORT=6432                        # PgBouncer port; gunakan 5432 untuk akses langsung ke axiom_db

# Database names (dua database terpisah di satu cluster Postgres)
DB_NAME_AXIOM=axiom_memories
DB_NAME_CRYPTOBOT=cryptobot_db

# Database admin (untuk init.sql dan migrations)
DB_ADMIN_USER=aru_admin
DB_ADMIN_PASSWORD=                  # generate manual: openssl rand -base64 32 | tr -dc A-Za-z0-9 | head -c 32

# Database users (per-service, dengan GRANT terbatas)
DB_USER_AXIOM=axiom_user
DB_PASSWORD_AXIOM=REPLACE_AXIOM_DB_PW          # auto-generated by setup script

DB_USER_CRYPTOBOT=cryptobot_user
DB_PASSWORD_CRYPTOBOT=REPLACE_CRYPTOBOT_DB_PW # auto-generated by setup script

DB_USER_OBSERVER=readonly_observer
DB_PASSWORD_OBSERVER=REPLACE_OBSERVER_DB_PW   # auto-generated by setup script

DB_USER_PARAMSYNC=parameter_sync_user
DB_PASSWORD_PARAMSYNC=REPLACE_PARAMSYNC_DB_PW # auto-generated by setup script

DB_USER_N8N=n8n_user
DB_PASSWORD_N8N=REPLACE_N8N_DB_PW              # auto-generated by setup script

# PgBouncer admin (untuk SHOW STATS)
PGB_ADMIN_USER=pgbouncer_admin
PGB_ADMIN_PASSWORD=REPLACE_PGB_ADMIN_PW        # auto-generated by setup script

# === REDIS ===
REDIS_URL=redis://:${REDIS_PASSWORD}@axiom_redis:6379
REDIS_PASSWORD=REPLACE_REDIS_PW                # auto-generated by setup script

# === N8N (workflow automation) ===
N8N_USER=aru009
N8N_PASSWORD=REPLACE_N8N_BASIC_PW              # auto-generated by setup script
N8N_HOST=axiom_n8n
N8N_PORT=5678
WEBHOOK_URL=http://axiom_n8n:5678/webhook/

# === BOT BEHAVIOR ===
PAPER_TRADE=true                    # set false hanya setelah validation passed (lihat R10)
INITIAL_CAPITAL=213
DAILY_TARGET_PCT=3.0                # turunkan dari 9.1% per Konflik 10
DRAWDOWN_LIMIT_PCT=15.0             # circuit breaker hard cap

# === TIMEZONE ===
BOT_TIMEZONE=Asia/Jakarta

# === AUTH (crypto-bot dashboard PIN) ===
# Generate: python -c "import hashlib; print(hashlib.sha256('YOUR_PIN'.encode()).hexdigest())"
BOT_PIN_HASH=

# === FRONTEND (dashboard URL) ===
# Untuk M1 local: kosong (dev server auto)
# Untuk M2+ VPS: full URL dengan https
FRONTEND_URL=

# === VPS ===
VPS_IP=                             # diisi setelah Phase 2 provisioning
DOMAIN_NAME=                        # mis. trading.aru009.com

# === BACKUP (Backblaze B2) ===
# Get from: https://www.backblaze.com → B2 Cloud Storage → Application Keys
BACKBLAZE_B2_KEY_ID=
BACKBLAZE_B2_APP_KEY=
BACKBLAZE_B2_BUCKET=axiom-backups

# === MULTI-EXCHANGE INTELLIGENCE (axiom-only, ccxt) ===
# Optional: API keys untuk read-only data fetching
# Bybit sudah include di BYBIT_* di atas
BINANCE_API_KEY=                    # optional, untuk axiom multi-exchange monitor
BINANCE_API_SECRET=                 # optional
OKX_API_KEY=                        # optional
OKX_API_SECRET=                     # optional
OKX_API_PASSPHRASE=                 # optional

# === FEATURE FLAGS (untuk axiom AI capabilities) ===
# Layer 1+2 (Phase 3)
FEATURE_PATTERN_LAYER1_ENABLED=false
FEATURE_PATTERN_LAYER2_ENABLED=false

# Layer 3 (Phase 4 awal)
FEATURE_RL_BANDIT_ENABLED=false
FEATURE_RL_OFFLINE_ENABLED=false

# Layer 4 (Phase 4 lanjutan, default OFF sampai trust earned)
FEATURE_AUTO_PARAM_REWRITE=false
FEATURE_AUTO_CODE_REWRITE=false
FEATURE_AUTO_APPROVE_ENABLED=false  # human-in-the-loop default; tetap false 90 hari pertama

# Pattern thresholds (tunable)
PATTERN_REGIME_CHAOS_THRESHOLD_VAR=2.5
PATTERN_LIQUIDITY_COLLAPSE_THRESHOLD=0.3
PATTERN_CORRELATION_SPIKE_THRESHOLD=0.95
PATTERN_NEWS_SHOCK_COUNT_THRESHOLD=3
PATTERN_NEWS_SHOCK_WINDOW_MIN=30

# === LOGGING ===
LOG_LEVEL=INFO                      # DEBUG / INFO / WARN / ERROR
LOG_RETENTION_DAYS=30

# === DEPRECATED (post-migration, tetap empty) ===
# Variabel di bawah ini dipertahankan agar code crypto-bot lama tidak crash,
# tapi nilai di-isi dummy karena Supabase sudah di-replace ke local Postgres.
# Hapus setelah asyncpg migration full done.
SUPABASE_URL=https://deprecated.example.com
SUPABASE_SERVICE_KEY=deprecated_dummy_key
